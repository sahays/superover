# Service Naming (namespaces Cloud Run services and Firestore collections)
SERVICE_NAME=super-over

# GCP Configuration
GCP_PROJECT_ID=your-project-id
GCP_REGION=asia-south1

# GCS Buckets
UPLOADS_BUCKET=your-uploads-bucket
PROCESSED_BUCKET=your-processed-bucket
RESULTS_BUCKET=your-results-bucket

# Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_DEFAULT_MODEL=models/gemini-3-pro-preview
GEMINI_DEFAULT_OUTPUT_TOKENS=65536
GEMINI_IMAGE_MODEL=models/gemini-3-pro-image-preview
GEMINI_IMAGE_OUTPUT_TOKENS=32768

# Firestore
FIRESTORE_DATABASE=(default)

# Local Development
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=local

# Video Processing Settings
MAX_VIDEO_SIZE_MB=500
CHUNK_DURATION_SECONDS=30
COMPRESS_RESOLUTION=720p
TEMP_STORAGE_PATH=./storage/temp

# Worker Settings
WORKER_POLL_INTERVAL_SECONDS=5
MAX_CONCURRENT_TASKS=3

# Scene Processing
SCENE_PROCESSING_MODE=sequential
MAX_GEMINI_WORKERS=10
