# ----------------------------------------------------
# Super Over Alchemy - Environment Configuration
#
# Copy this file to .env and fill in your specific values.
# The .env file is ignored by git and should not be committed.
# ----------------------------------------------------

# --- GCP Project Configuration ---
GCP_PROJECT_ID="your-gcp-project-id"
GCP_REGION="us-central1"

# --- GCS Bucket Configuration ---
# Must be globally unique names.
RAW_UPLOADS_BUCKET_NAME="your-project-raw-uploads-bucket"
PROCESSED_OUTPUTS_BUCKET_NAME="your-project-processed-outputs-bucket"

# --- Service and Workflow Names ---
# The name of the deployed Cloud Workflow orchestrator.
WORKFLOW_NAME="pipeline-orchestrator"
# The name of the service account for Pub/Sub to invoke Cloud Run.
INVOKER_SERVICE_ACCOUNT_NAME="pubsub-invoker"

# --- Gemini API Configuration ---
# For production, it is STRONGLY recommended to manage this key using Google Secret Manager.
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="models/gemini-1.5-pro-latest"

# --- Video Processor Configuration ---
CHUNK_DURATION="60"
COMPRESS_RESOLUTION="720p"
COMPRESS_FIRST="false"
